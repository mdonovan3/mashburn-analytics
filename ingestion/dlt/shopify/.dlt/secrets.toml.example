# Copy this file to secrets.toml (gitignored) and fill in a real value.

[sources.shopify]
access_token = "shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# BigQuery: leave [destination.bigquery.credentials] unset to fall back to
# Application Default Credentials (gcloud auth application-default login),
# matching the rest of this project — see ../../../CONNECTION.md. Only add
# a [destination.bigquery.credentials] block if using a service account
# key file instead.
