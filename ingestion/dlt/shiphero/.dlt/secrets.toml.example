# Copy this file to secrets.toml (gitignored) and fill in a real value.

[sources.shiphero]
# Long-lived refresh token from a ShipHero Third-Party Developer user
# (Settings -> API in the ShipHero account). The pipeline exchanges this
# for a short-lived access token on every run — see shiphero_source.py.
refresh_token = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# BigQuery: leave [destination.bigquery.credentials] unset to fall back to
# Application Default Credentials (gcloud auth application-default login),
# matching the rest of this project — see ../../../CONNECTION.md.
